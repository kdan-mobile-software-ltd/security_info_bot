# TWCERT 企業會員（僅 TWCERT 流程需要）
TWCERT_ACCOUNT=
TWCERT_PASSWORD=

# Google Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Google Service Account（擇一設定）
GOOGLE_SA_JSON_B64=
# GOOGLE_SA_JSON_FILE=./service_account.json

# Google Sheet
GOOGLE_SHEET_ID=
ASSETS_SHEET_ID=

# Git archive branch（留空則停用；CI 另設 GIT_ARCHIVE_AUTO_PUSH=true）
GIT_ARCHIVE_BRANCH=data

# 開發模式：使用 tests/fixtures 樣板資料
USE_FIXTURE_DATA=true

# --- Email 發佈層 (Stage 4a 風險小組月信 / Stage 4b 內部發佈) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=secbot@example.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=資安情資Bot <secbot@example.com>
RISK_TEAM_EMAILS=risk-a@example.com,risk-b@example.com
INTERNAL_ANNOUNCE_EMAILS=rd-managers@example.com
